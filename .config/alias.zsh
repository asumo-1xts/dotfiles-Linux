# apt
abbr -S apa='sudo apt autoremove'
abbr -S api='sudo apt install'
abbr -S app='sudo apt purge'
abbr -S apr='sudo apt remove'
abbr -S apu='sudo apt update && sudo apt upgrade'
clear
# Git
abbr -S gad="git add"
abbr -S gbr="git branch"
abbr -S gbrd="git branch -d"
abbr -S gbrdo="git branch -d origin/"
abbr -S gcl="git clone"
abbr -S gch="git checkout"
abbr -S gchb="git checkout -b"
abbr -S gcm="git commit -m"
abbr -S gcma="git commit --amend -m"
abbr -S gcme="git commit --allow-empty -m"
abbr -S gin="git init && git branch -m main"
abbr -S glg="git log --oneline"
abbr -S gpl="git pull origin"
abbr -S gps="git push origin"
abbr -S grao="git remote add origin"
abbr -S grro="git remote remove origin"
abbr -S grh="git reset --hard HEAD^"
abbr -S grho="git reset --hard origin/"
abbr -S grs="git reset --soft HEAD^"
abbr -S gss="git stash -u"
abbr -S gssa="git stash apply"
abbr -S gst="git status"
clear
# mise
abbr -S mi="mise install"
abbr -S ml="mise list"
abbr -S mr="mise run"
abbr -S mrm="mise remove"
abbr -S mtr="mise trust"
clear
# Yarn
abbr -S ya="yarn add -D"
abbr -S yb="yarn build"
abbr -S yd="yarn dev"
abbr -S yga="yarn global add"
abbr -S ygr="yarn global remove"
abbr -S yi="yarn install"
abbr -S yr="yarn run"
abbr -S yrm="yarn remove -D"
abbr -S yt="yarn test"
clear
# シンボリックリンク
abbr -S sl="ln -nfs <decoy> <body>"
abbr -S sll="find ~/.config -type l"
abbr -S sul="unlink <body>"
clear